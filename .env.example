# --- Twilio credentials (from console.twilio.com) ---
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here

# The single Twilio number that BOTH parties will see as the caller ID.
# This is what masks the two real numbers from each other.
TWILIO_NUMBER=+15551234567

# Public base URL where Twilio can reach THIS server's webhooks.
# Locally, run `ngrok http 3000` and paste the https URL it gives you (no trailing slash).
# In production, this is your deployed https domain.
BASE_URL=https://your-subdomain.ngrok-free.app

# Port the server listens on locally.
PORT=3000

# How long (seconds) to ring each party before giving up.
RING_TIMEOUT=20

# Set "true" in production to reject any webhook request not signed by Twilio.
# Leave "false" for quick local testing (signature validation needs BASE_URL to
# exactly match the public URL Twilio is hitting).
VALIDATE_TWILIO_REQUESTS=false

# Optional: detect if party A's voicemail picks up so we don't bridge B into it.
# "true" enables Twilio Answering Machine Detection on the call to A.
USE_MACHINE_DETECTION=false
